#!/usr/bin/env bash
# nordvpn-helper — Privileged helper for nordvpn CLI
# shellcheck disable=SC2155
#
# Runs as root via sudoers NOPASSWD. Only allows specific, scoped VPN operations.
# Principle of least privilege: the main nordvpn script is unprivileged and
# delegates only the operations that require root to this helper.
#
# DO NOT call this script directly — it is invoked by nordvpn via:
#   sudo -n ~/.nordvpn/nordvpn-helper <command> [args]

set -euo pipefail

CMD="${1:-}"
shift || true

OPENVPN_BIN="/opt/homebrew/opt/openvpn/sbin/openvpn"
PID_FILE="/tmp/nordvpn-openvpn.pid"
LOG_FILE="/tmp/nordvpn-openvpn.log"

case "$CMD" in
    openvpn-start)
        # $1=ovpn_config_path, $2=auth_file_path
        rm -f "$LOG_FILE"
        touch "$LOG_FILE"
        chmod 644 "$LOG_FILE"
        "$OPENVPN_BIN" \
            --config "$1" \
            --auth-user-pass "$2" \
            --daemon "nordvpn" \
            --writepid "$PID_FILE" \
            --log "$LOG_FILE" \
            --connect-retry 3 \
            --connect-timeout 30 \
            --verb 3
        chmod 644 "$PID_FILE"
        ;;

    openvpn-stop)
        if [[ -f "$PID_FILE" ]]; then
            local_pid=$(cat "$PID_FILE")
            kill "$local_pid" 2>/dev/null || true
            # Wait up to 10s for graceful shutdown
            for i in $(seq 1 10); do
                kill -0 "$local_pid" 2>/dev/null || break
                sleep 1
            done
            # Force kill if still running
            kill -0 "$local_pid" 2>/dev/null && kill -9 "$local_pid" 2>/dev/null || true
            rm -f "$PID_FILE"
        fi
        ;;

    openvpn-kill-all)
        pkill -f "openvpn.*nordvpn" 2>/dev/null || true
        rm -f "$PID_FILE"
        ;;

    check-pid)
        [[ -f "$PID_FILE" ]] || exit 1
        kill -0 "$(cat "$PID_FILE")" 2>/dev/null || exit 1
        cat "$PID_FILE"
        ;;

    set-dns)
        # $1=network_service, $2=dns1, $3=dns2
        /usr/sbin/networksetup -setdnsservers "$1" "$2" "$3"
        dscacheutil -flushcache 2>/dev/null || true
        killall -HUP mDNSResponder 2>/dev/null || true
        ;;

    clear-dns)
        # $@=list of service names (Wi-Fi, Ethernet, ...)
        for svc in "$@"; do
            /usr/sbin/networksetup -setdnsservers "$svc" Empty 2>/dev/null || true
        done
        dscacheutil -flushcache 2>/dev/null || true
        killall -HUP mDNSResponder 2>/dev/null || true
        ;;

    route-restore)
        # $1=original_gateway_ip
        /sbin/route -n delete -net 0.0.0.0/1   2>/dev/null || true
        /sbin/route -n delete -net 128.0.0.0/1  2>/dev/null || true
        /sbin/route -n delete -net 10.100.0.0/16 2>/dev/null || true
        /sbin/route -n delete default            2>/dev/null || true
        /sbin/route -n add default "$1"          2>/dev/null || true
        ;;

    *)
        echo "nordvpn-helper: unknown command: $CMD" >&2
        exit 1
        ;;
esac
